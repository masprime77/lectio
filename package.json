{
  "name": "semester-planner",
  "version": "1.0.0",
  "description": "A minimal semester planner desktop app backed by JSON files",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev-tools",
    "build:mac": "electron-builder --mac"
  },
  "keywords": [
    "semester",
    "planner",
    "university",
    "study",
    "electron"
  ],
  "license": "MIT",
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.tu-usuario.semester-planner",
    "productName": "Semester Planner",
    "mac": {
      "category": "public.app-category.productivity",
      "target": ["dmg", "zip"]
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "app.js",
      "style.css",
      "semesters/"
    ],
    "extraResources": [
      { "from": "semesters/", "to": "semesters/" }
    ]
  }
}
